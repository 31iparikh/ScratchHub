<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ScratchHub - Play Unblocked Scratch Games</title>
    <link rel="stylesheet" href="style.css">
</head>
































































<body>
    <div class="hexagon-container" id="hexContainer"></div>
































    <div class="auth-overlay" id="authOverlay" role="dialog" aria-modal="true" aria-labelledby="authTitle">
        <div class="auth-card">
            <h2 id="authTitle">Sign In / Sign Up</h2>
            <div class="auth-switch">
                <button id="btnSignIn" class="auth-mode active">Sign In</button>
                <button id="btnSignUp" class="auth-mode">Sign Up</button>
            </div>
            <div class="auth-form">
                <label>Username<input id="authUser" type="text" placeholder="Enter username"></label>
                <label>Password<input id="authPass" type="password" placeholder="Enter password"></label>
                <button id="authSubmit" class="cta-btn">Continue</button>
                <p id="authMessage" class="auth-message"></p>
            </div>
        </div>
    </div>
































    <div class="content-overlay">
        <header class="scratch-header">
            <h1 class="scratch-title">🎯ScratchHub</h1>
            <p class="scratch-tagline">Play the Best Unblocked Scratch Games</p>
        </header>
































        <nav class="page-nav" aria-label="Main pages">
            <button class="page-btn active" data-page="home">Home</button>
            <button class="page-btn" data-page="games">Games</button>
            <button class="page-btn" data-page="topPlayers">Top Players</button>
            <button class="page-btn" data-page="ai">🤖 Ask AI</button>
        </nav>
































        <section class="page active" id="home">
            <div class="user-bar">
                <span id="currentUser">Guest</span>
                <button id="logoutBtn" class="small-btn">Sign Out</button>
            </div>
            <div class="status-badge" id="statusBadge">✨ Live: 4 games | 8,724 players online</div>
































        <a class="cta-btn" href="#games">🎮 Jump into games</a>
































        <div class="action-row">
            <div class="filter-group" id="filterGroup">
                <button class="filter-btn active" data-filter="all">All</button>
                <button class="filter-btn" data-filter="arcade">Arcade</button>
                <button class="filter-btn" data-filter="puzzle">Puzzle</button>
                <button class="filter-btn" data-filter="strategy">Strategy</button>
            </div>
            <button class="random-btn" id="randomGameBtn">🎯 Random Challenge</button>
        </div>
































        <div class="recent-row" id="recentRow">Recently played: <span id="recentGames">None yet</span></div>
































        <div class="games-grid" id="games">
            <div class="game-card card-red game-embed-card" data-category="arcade" data-rating="4.9" data-plays="12832" onclick="openGame('https://scratch.mit.edu/projects/1292909401/embed', '🎮 Geometry Dash Wave')">
                <div class="card-meta">⏱ 3 min • ⭐ 4.9 • 🔥 12.8k plays</div>
                <div class="card-icon">🎮</div>
                <h3>Geometry Dash Wave</h3>
                <p>Click to play this intense geometry game!</p>
            </div>
   
            <div class="game-card card-orange game-embed-card" data-category="arcade" data-rating="4.7" data-plays="9840" onclick="openGame('https://scratch.mit.edu/projects/1293362123/embed', '🏓Pong Ping')">
                <div class="card-meta">⏱ 2 min • ⭐ 4.7 • 🔥 9.8k plays</div>
                <div class="card-icon">🏓</div>
                <h3>Pong Ping</h3>
                <p>Survive the ultimate Pong Ping challenge!</p>
            </div>
           
            <div class="game-card card-yellow" data-category="strategy" data-rating="4.6" data-plays="7600" onclick="openGame('https://scratch.mit.edu/projects/1078734179/embed', '♟️Scratch Chess')">
                <div class="card-meta">⏱ 5 min • ⭐ 4.6 • 🔥 7.6k plays</div>
                <div class="card-icon">♟️</div>
                <h3>Scratch Chess</h3>
                <p>Play Chess On Scratch!</p>
            </div>
           
            <div class="game-card card-green" data-category="arcade" data-rating="4.4" data-plays="6480" onclick="openGame('https://scratch.mit.edu/projects/983655397/embed', '👾Minecraft Dash v3')">
                <div class="card-meta">⏱ 4 min • ⭐ 4.4 • 🔥 6.5k plays</div>
                <div class="card-icon">👾</div>
                <h3>Minecraft Dash v3</h3>
                <p>Geometry Dash But Minecraft</p>
            </div>
           
            <div class="game-card card-blue" data-category="puzzle" data-rating="4.5" data-plays="5230" onclick="openGame('https://scratch.mit.edu/projects/1051860555/embed', '🍕Pizza Shop Madness')">
                <div class="card-meta">⏱ 6 min • ⭐ 4.5 • 🔥 5.2k plays</div>
                <div class="card-icon">🍕</div>
                <h3>Pizza Shop Madness</h3>
                <p>Run your own pizza restaurant!</p>
            </div>
           
            <div class="game-card card-purple" data-category="strategy" data-rating="4.3" data-plays="4320" onclick="openGame('https://scratch.mit.edu/projects/2233445566/embed', '⚡Lightning Quest')">
                <div class="card-meta">⏱ 7 min • ⭐ 4.3 • 🔥 4.3k plays</div>
                <div class="card-icon">⚡</div>
                <h3>Lightning Quest</h3>
                <p>Epic adventure awaits!</p>
            </div>
        </div>
        </section>
































        <section class="page" id="games">
            <h2 class="section-heading">All Games</h2>
            <div class="games-grid" id="gamesGridCopy">
                <!-- Duplicate of first set for more content -->
            </div>
        </section>
































        <section class="page" id="topPlayers">
            <h2 class="section-heading">Top Players</h2>
            <ul class="leaderboard">
                <li><strong>1.</strong> AceGamer - 21,409 points</li>
                <li><strong>2.</strong> NeonNinja - 19,878 points</li>
                <li><strong>3.</strong> PixelPro - 18,234 points</li>
                <li><strong>4.</strong> GeoDash - 16,999 points</li>
                <li><strong>5.</strong> PuzzleMaster - 15,740 points</li>
            </ul>
        </section>
















        <section class="page" id="ai">
            <h2 class="section-heading">🤖 Ask AI Anything</h2>
            <p style="color: #aaa; margin-bottom: 20px;">Ask any question and the AI will search the web and provide answers</p>
            <div class="ai-chat-container">
                <div class="chat-messages" id="chatMessages"></div>
                <div class="chat-input-area">
                    <input type="text" id="chatInput" class="chat-input" placeholder="Ask me anything... (What is photosynthesis? How does AI work? etc)" />
                    <button id="sendButton" class="send-btn">Send</button>
                </div>
            </div>
        </section>
































        <footer class="scratch-footer">
            <p>All games are 100% unblocked and playable on any device 🎮</p>
        </footer>
        <footer>
    <small>
        &copy; <span id="year"></span> ScratchHub. All Rights Reserved for Scratch.mit.edu.
    </small>
</footer>
    </div>
































































































    <!-- Game Modal for Embedded Game -->
    <div class="game-modal" id="gameModal">
        <div class="modal-content">
            <button class="close-btn" onclick="closeGameModal()">&times;</button>
            <h2 class="modal-title" id="modalTitle">🎮 Play Game</h2>
            <div class="game-embed-container" id="embedContainer">
            </div>
        </div>
    </div>
































































<script src="script.js"></script>
</body>
</html>

















































































































